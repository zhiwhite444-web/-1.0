{
  "manifest_version": 3,
  "name": "SillyTavern GrokChat Theme",
  "version": "1.0.0",
  "description": "GrokChat 风格的 SillyTavern UI 美化主题 - 可折叠侧边栏、毛玻璃效果",
  "author": "zhiwhite444",
  "type": "theme",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles/grokchat-theme.css"],
      "js": ["scripts/grokchat-overlay.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": [],
  "web_accessible_resources": [
    {
      "resources": ["styles/grokchat-theme.css", "scripts/grokchat-overlay.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
